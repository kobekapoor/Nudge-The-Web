---
import MainLayout from "../../layouts/MainLayout.astro";
import Contact from "../../components/sections/Contact.astro";
import GridOverlay from "../../components/ui/GridOverlay.astro";

const caseStudies = [
  {
    href: '/case-studies/separovic-lawyers',
    client: 'Separovic Injury Lawyers',
    industry: 'Legal',
    location: 'Perth, WA',
    headline: 'How We Saved Over $18,000/Year',
    summary: 'Migrated from HubSpot Marketing Pro to a purpose-built Zapier automation stack, cutting annual software costs by ~92% while preserving every workflow.',
    stats: [
      { value: '$16,400+', label: 'Annual savings' },
      { value: '~92%', label: 'Cost reduction' },
      { value: '30 hrs', label: 'Project delivery' },
    ],
    tags: ['Business Automation', 'Revenue Operations'],
  },
  {
    href: '/case-studies/basketball-magic',
    client: 'Basketball Magic Australia',
    industry: 'Sports & Events',
    location: 'Australia',
    headline: 'HubSpot Website for an NBA-Licensed Tour Operator',
    summary: 'Built a conversion-focused website on HubSpot Content Hub with CRM integration, automated workflows, and modular content — in partnership with agency Now We Collide.',
    stats: [
      { value: '8–9 wks', label: 'Project delivery' },
      { value: '3+', label: 'Audiences served' },
      { value: '1 platform', label: 'Website + CRM + automation' },
    ],
    tags: ['HubSpot Development', 'Website Development'],
  },
  // {
  //   href: '/case-studies/circles-of-hair-booking',
  //   client: 'Circles of Hair',
  //   industry: 'Beauty & Wellness',
  //   location: 'Perth, WA',
  //   headline: 'Solving the Attribution Problem with a Custom Booking App',
  //   summary: 'Replaced Timely with a custom WooCommerce booking platform — giving a multi-location salon full attribution tracking across Google Ads and Meta for the first time.',
  //   stats: [
  //     { value: 'Full', label: 'Attribution tracking' },
  //     { value: '4', label: 'Tools integrated' },
  //     { value: '0', label: 'Data silos' },
  //   ],
  //   tags: ['Website Development', 'Analytics Tracking'],
  // },
  // {
  //   href: '/case-studies/circles-of-hair-hubspot',
  //   client: 'Circles of Hair',
  //   industry: 'Beauty & Wellness',
  //   location: 'Perth, WA',
  //   headline: 'HubSpot CRM, Reporting & Email Marketing — Phase 2',
  //   summary: 'Connected a custom booking system to HubSpot to build full channel-to-revenue reporting, automate email marketing, and structure a 6,000+ contact database.',
  //   stats: [
  //     { value: '6,000+', label: 'Segmented contacts' },
  //     { value: '90 hrs', label: 'Implementation' },
  //     { value: '5', label: 'Data sources connected' },
  //   ],
  //   tags: ['HubSpot Development', 'Revenue Operations'],
  // },
];
---

<MainLayout
  title="Case Studies | Nudge The Web"
  description="Real results for real businesses. See how Nudge The Web helps companies cut costs, automate workflows, and grow revenue."
>
  <!-- Hero -->
  <section class="relative bg-dark overflow-hidden">
    <GridOverlay />
    <div class="relative mx-auto max-w-7xl px-6 lg:px-8 py-24 sm:py-32">
      <span class="inline-flex bg-orange/10 px-3 py-1 text-sm font-semibold text-orange ring-1 ring-inset ring-orange/30">
        Case Studies
      </span>
      <h1 class="mt-6 text-pretty text-4xl font-semibold tracking-tight text-white sm:text-6xl max-w-3xl">
        Real Results for<span class="text-orange"> Real Businesses</span>
      </h1>
      <p class="mt-6 text-lg text-gray-400 max-w-xl">
        A look at how we've helped businesses cut costs, eliminate manual work, and grow — with measurable outcomes.
      </p>
    </div>
  </section>

  <!-- Case Study Cards -->
  <section class="bg-gray py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {caseStudies.map((study, i) => (
          <a
            href={study.href}
            class="group bg-white border border-gray-200 p-8 flex flex-col gap-6 hover:shadow-lg hover:border-orange transition-all duration-200 intersect-once intersect:motion-preset-slide-right"
            style={`motion-delay: ${i * 100}ms`}
          >
            <!-- Header -->
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <div class="flex flex-wrap gap-2 mb-3">
                  <span class="text-xs font-semibold uppercase tracking-widest text-orange bg-orange/10 px-2 py-1">
                    {study.industry}
                  </span>
                  <span class="text-xs font-semibold uppercase tracking-widest text-gray-500 bg-gray-100 px-2 py-1">
                    {study.location}
                  </span>
                </div>
                <h2 class="text-2xl font-semibold text-dark group-hover:text-orange transition-colors duration-200">{study.client}</h2>
              </div>
            </div>

            <!-- Headline + Summary -->
            <div>
              <p class="text-xl font-semibold text-orange mb-2">{study.headline}</p>
              <p class="text-gray-600 leading-relaxed">{study.summary}</p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {study.tags.map(tag => (
                <span class="text-xs font-medium text-gray-500 border border-gray-200 px-3 py-1">
                  {tag}
                </span>
              ))}
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-3 gap-4 border-t border-gray-100 pt-6">
              {study.stats.map(stat => (
                <div class="text-center">
                  <div class="text-2xl font-semibold text-dark">{stat.value}</div>
                  <div class="text-xs text-gray-500 mt-1 uppercase tracking-wider">{stat.label}</div>
                </div>
              ))}
            </div>

            <!-- Link -->
            <div class="flex justify-end mt-auto pt-2">
              <span class="inline-flex items-center gap-2 text-sm font-semibold text-orange group-hover:underline">
                Read case study
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200">
                  <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-orange py-16 mb-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-semibold text-dark mb-6">
        Want results like these? Let's talk.
      </h2>
      <a href="#contact" class="btn-primary px-10 py-4 bg-dark text-white hover:bg-white hover:text-dark">
        Get in touch
      </a>
    </div>
  </section>

  <!-- Contact -->
  <Contact />
</MainLayout>
