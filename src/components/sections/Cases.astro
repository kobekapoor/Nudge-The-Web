---
import Section from "./Section.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import CaseStudyCard from "../ui/CaseStudyCard.astro";
import caseStudies from "../../data/caseStudies.json";

const featured = caseStudies.slice(0, 3);
const delays = ['motion-delay-[.1s]', 'motion-delay-[.3s]', 'motion-delay-[.5s]'];
---

<Section id="cases">
  <div class="py-20">
    <div class="intersect-once intersect:motion-preset-slide-right">
      <SectionTitle
        sectionTitle="Case Studies"
        description="Real results for real businesses. See how we've helped clients grow through smarter websites, cleaner data, and streamlined operations."
      />
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-10">
      {featured.map((cs, i) => (
        <div class={`intersect-once intersect:motion-preset-slide-right ${delays[i]}`}>
          <CaseStudyCard
            client={cs.client}
            title={cs.title}
            resultHeadline={cs.resultHeadline}
            services={cs.services}
            slug={cs.slug}
            colorVariant={cs.colorVariant}
            results={cs.results}
          />
        </div>
      ))}
    </div>

    {caseStudies.length > 3 && (
      <div class="mt-12 flex justify-center intersect-once intersect:motion-preset-slide-right motion-delay-[.6s]">
        <a href="/case-studies" class="btn-primary">View All Case Studies</a>
      </div>
    )}
  </div>
</Section>
